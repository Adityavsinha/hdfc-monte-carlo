{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Test Single Stock",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/test_one_stock.py",
      "args": ["RELIANCE"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {}
    },
    {
      "name": "Fetch Prices (Screener Data)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/fetch_prices.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run Full Pipeline",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_pipeline.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Store Today's Signals",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/backtest.py",
      "args": ["store"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Evaluate Backtest (30 days)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/backtest.py",
      "args": ["evaluate", "30"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Test Telegram Post",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/post_telegram.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
