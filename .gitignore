# ============================================
# QuantEdge Analytics .gitignore
# ============================================

# Python
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Secrets — NEVER upload these
.env
*.key
*.pem
*.p12
credentials.json
token.json
service_account.json

# Logs
logs/
*.log
*.log.*

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# VS Code (keep settings but not user-specific)
.vscode/settings.json
# Note: we keep .vscode/extensions.json (useful for team)

# Test outputs
docs/test_*.json
docs/nifty50_data.json

# Large generated files (regenerated by pipeline)
# Uncomment these if you don't want them in git:
# docs/metrics.json
# docs/charts.json

# Python cache
.mypy_cache/
.pytest_cache/
.hypothesis/
