# QuantEdge Analytics — Local Environment Variables
# =====================================================
# IMPORTANT: This file stays on YOUR machine only.
# It is listed in .gitignore so it NEVER uploads to GitHub.
# GitHub uses its own Secrets (Settings → Secrets and variables → Actions)
#
# HOW TO FILL THIS IN:
# 1. Replace "your_xxx_here" with your actual values
# 2. Save the file
# 3. Your Python scripts will automatically load these values
# =====================================================

# ── Telegram Bot (for daily signal posting) ──────────
# Get from: Talk to @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your channel: create a public channel like @quantedge_signals
# Then add your bot as Admin
TELEGRAM_CHANNEL_ID=@your_channel_here

# ── Firebase (for user auth and watchlist) ────────────
# Get from: console.firebase.google.com → Project Settings → Web App
FIREBASE_API_KEY=your_api_key_here
FIREBASE_PROJECT_ID=your_project_id

# ── Razorpay (for payments — fill when ready) ─────────
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_secret_here

# ── Development settings ──────────────────────────────
# Set to "true" to run pipeline on only 5 stocks (much faster for testing)
DEV_MODE=false
DEV_STOCKS=RELIANCE,HDFCBANK,TCS,NTPC,INFOSYS
